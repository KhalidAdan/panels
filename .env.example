# Node
NODE_ENV=development

# Database
DATABASE_URL=file:./prisma/dev.db

# Better Auth
BETTER_AUTH_SECRET=change-me-at-least-32-chars-long-xxxxxxxxx
BETTER_AUTH_URL=http://localhost:5173

# File system
LIBRARY_PATH=./data/library
CACHE_PATH=./data/cache
UPLOAD_TEMP_PATH=./data/tmp
MAX_UPLOAD_SIZE=4294967296  # 4 GB default, can be any byte value

# Optional — Phase 5
# COMICVINE_API_KEY=

# Seed (Phase 1) — creates an admin user on first migrate-deploy
SEED_ADMIN_EMAIL=admin@example.com
SEED_ADMIN_PASSWORD=change-me-please