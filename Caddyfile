# Replace comics.example.com with your real domain. For a Tailscale
# or LAN-only deployment, use the machine's LAN hostname and Caddy
# will generate a self-signed cert (see `tls internal` variant below).

{
  # Optional: disable the admin API if you don't need it.
  admin off
}

comics.example.com {
  encode zstd gzip

  # Request body limit — CBZ uploads can be large.
  request_body {
    max_size 2GB
  }

  # Forward real client IP + scheme so rate limits, logs, and the
  # auth cookie's Secure/SameSite behavior work correctly.
  reverse_proxy panels:3000 {
    header_up X-Real-IP {remote_host}
    header_up X-Forwarded-For {remote_host}
    header_up X-Forwarded-Proto {scheme}

    # Large uploads need longer timeouts. 10 minutes is generous;
    # tune down if you want stricter behavior.
    transport http {
      read_timeout 10m
      write_timeout 10m
      dial_timeout 30s
    }
  }

  # Health check — skip the reverse proxy for the simplest path.
  # Uncomment if you want Caddy itself to answer 200 on the root
  # during brief panel restarts.
  # respond /caddy-health 200
}

# ── LAN / Tailscale variant ─────────────────────────────────────────
# Uncomment and adapt if you're not exposing to the public internet.
