# Copy to .env.production and fill in. docker-compose reads .env by
# default; rename as appropriate for your deploy setup.

# Public URL (must match the one Caddy serves)
BETTER_AUTH_URL=https://comics.example.com

# 32+ random chars. Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
BETTER_AUTH_SECRET=paste-a-real-secret-here

# Host directory to bind-mount at /data/library inside the container.
# Absolute path.
PANELS_LIBRARY_PATH=/srv/comics

# Optional
COMICVINE_API_KEY=
COMICVINE_USER_AGENT=panels/0.1 (self-hosted comic reader)

# Seed credentials — used on first boot against an empty DB. Once
# the first user exists, these env vars are ignored even if set.
SEED_ADMIN_EMAIL=admin@example.com
SEED_ADMIN_PASSWORD=change-me-to-something-long

TZ=America/Toronto
